rule RERUN_CMAKE
  command = C:\Users\janeg\.pico-sdk\cmake\v3.31.5\bin\cmake.exe --regenerate-during-build -SC:\dev\WIZnet-PICO-C -BC:\dev\WIZnet-PICO-C\build-pico2
  description = Re-running CMake...
  generator = 1


